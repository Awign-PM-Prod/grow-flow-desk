# Frontend (Vite) environment.
# The browser talks ONLY to the backend gateway below; it never calls Supabase
# directly. The backend forwards requests to Supabase.
VITE_API_URL=http://localhost:4000

# Public Supabase anon key. Required by the Supabase JS SDK (not a secret).
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key"

VITE_SITE_URL=http://localhost:8080
