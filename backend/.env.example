NODE_ENV=development
PORT=4000

# Comma-separated list of frontend origins allowed to call this gateway.
CORS_ORIGIN=http://localhost:8080

# Supabase project the gateway forwards to.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional. NOT used by the transparent gateway (RLS is preserved via the user's
# JWT). Only set this if you later add privileged endpoints that must bypass RLS.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
